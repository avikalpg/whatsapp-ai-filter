# PostgreSQL connection string (e.g. Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret for signing JWT tokens — use a long random string
JWT_SECRET=your-very-long-random-secret-here

# Your Anthropic API key — used for the 24-hour free trial
ANTHROPIC_API_KEY=sk-ant-...

# 32-byte hex key for AES-256 encryption of user API keys
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-string-here

# Maximum USD spend allowed per user during their 24-hour free trial.
# Default: $5.00 — adjust to control your trial cost exposure.
# Example: TRIAL_BUDGET_USD=2.50
TRIAL_BUDGET_USD=5.00
